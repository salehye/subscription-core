{
    "name": "salehye/subscription-core",
    "description": "A powerful, extensible subscription management package for Laravel. Manage plans, features, subscriptions, and usage tracking with multi-tenancy support.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Saleh Al-Sanabani",
            "homepage": "https://github.com/salehye"
        }
    ],
    "homepage": "https://github.com/salehye/subscription-core",
    "keywords": [
        "laravel",
        "subscription",
        "plans",
        "features",
        "billing",
        "saas",
        "multi-tenancy"
    ],
    "require": {
        "php": "^8.3",
        "laravel/framework": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Salehye\\Subscription\\": "src/",
            "Salehye\\Subscription\\Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "src/Helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Salehye\\Subscription\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Salehye\\Subscription\\SubscriptionServiceProvider"
            ],
            "aliases": {
                "Subscription": "Salehye\\Subscription\\Facades\\Subscription"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
